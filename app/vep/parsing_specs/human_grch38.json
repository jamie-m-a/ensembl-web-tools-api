    {
      "plugin": "utr_annotation",
      "scope": "transcript",
      "output": "utr_annotation",
      "csq_fields": [
        "5UTR_consequence",
        "5UTR_annotation",
        "Existing_uORFs",
        "Existing_InFrame_oORFs",
        "Existing_OutOfFrame_oORFs"
      ],
      "require_any_input": [
        "5UTR_consequence",
        "5UTR_annotation",
        "Existing_uORFs",
        "Existing_InFrame_oORFs",
        "Existing_OutOfFrame_oORFs"
      ],
      "targets": [
        {
          "field": "consequence",
          "from": "5UTR_consequence",
          "transform": "scalar",
          "type": "string"
        },
        {
          "field": "annotation",
          "from": "5UTR_annotation",
