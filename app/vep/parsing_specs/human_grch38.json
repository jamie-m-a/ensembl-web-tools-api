        },
        {
          "field": "clinical_significance",
          "from": "CLIN_SIG",
          "transform": "list"
        },
        {
          "field": "pubmed_ids",
          "from": "PUBMED",
          "transform": "list"
        }
      ]
    },
    {
      "plugin": "dosage_sensitivity",
      "scope": "transcript",
      "output": "dosage_sensitivity",
      "csq_fields": [
        "pHaplo",
        "pTriplo"
      ],
      "require_any_input": [
        "pHaplo",
        "pTriplo"
      ],
      "targets": [
        {
          "field": "phaplo",
          "from": "pHaplo",
          "transform": "scalar",
          "type": "float"
        },
        {
          "field": "ptriplo",
          "from": "pTriplo",
          "transform": "scalar",
          "type": "float"
        }
      ]
    },
    {
      "plugin": "intact",
